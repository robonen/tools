{
  "extends": "@robonen/tsconfig/tsconfig.dom.json",
  "compilerOptions": {
    "composite": true,
    "types": [],
    "paths": {
      "@/*": ["./src/*"],
      "@/composables/*": ["./src/composables/*"],
      "@/types": ["./src/types"],
      "@/utils": ["./src/utils"]
    },
    "tsBuildInfoFile": "./node_modules/.tmp/tsconfig.src.tsbuildinfo"
  },
  "include": ["src/**/*.ts"]
}
