{
  "extends": "@robonen/tsconfig/tsconfig.json",
  "compilerOptions": {
    "lib": ["ESNext", "DOM"],
    "baseUrl": ".",
    "paths": {
      "@/*": ["src/*"]
    }
  },
  "vueCompilerOptions": {
    "strictTemplates": true,
    "fallthroughAttributes": true,
    "inferTemplateDollarAttrs": true,
    "inferTemplateDollarEl": true,
    "inferTemplateDollarRefs": true
  }
}